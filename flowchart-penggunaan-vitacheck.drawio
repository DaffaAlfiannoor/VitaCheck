        <!-- Akses URL → Cek JWT -->
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="s2" target="s3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Cek JWT → Decision Login -->
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="s3" target="d1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Decision Login → YA → Dashboard -->
        <mxCell id="e4" value="YA" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="d1" target="s4a">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Decision Login → TIDAK → Landing Page -->
        <mxCell id="e5" value="TIDAK" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" parent="1" source="d1" target="s4b">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Dashboard (YA) → menuju Isi Formulir -->
        <mxCell id="e5b" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="s4a" target="s5">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="670" y="640" />
              <mxPoint x="670" y="690" />
              <mxPoint x="550" y="690" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Landing Page → Isi Formulir -->
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="s4b" target="s5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Isi Formulir → Decision Form Lengkap -->
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="s5" target="d2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Decision Form → TIDAK → kembali ke Isi Formulir -->
        <mxCell id="e8" value="TIDAK" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="d2" target="s5">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="570" y="815" />
              <mxPoint x="570" y="690" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Decision Form → YA → Klik Tombol -->
        <mxCell id="e9" value="YA" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" parent="1" source="d2" target="s6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Klik Tombol → Kirim ke Backend -->
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="s6" target="s7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Kirim ke Backend → Validasi Pydantic -->
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="s7" target="s8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Validasi → StandardScaler -->
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="s8" target="s9">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- StandardScaler → Inferensi -->
        <mxCell id="e13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="s9" target="s10">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Inferensi → Tampil Hasil -->
        <mxCell id="e14" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="s10" target="s11">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Tampil Hasil → Decision Fitur Lain -->
        <mxCell id="e15" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="s11" target="d3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Decision Fitur Lain → YA → Fitur Tambahan -->
        <mxCell id="e16" value="YA" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="d3" target="s12">
          <mxGeometry relative="1" as="geometry" />
